{
  "version": 2,
  "builds": [
    { "src": "frontend/package.json", "use": "@vercel/vite" },
    { "src": "api/index.ts", "use": "@vercel/node" }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.ts" },
    { "source": "/(.*)", "destination": "/frontend/dist/index.html" }
  ]
}
